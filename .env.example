# -------------------------------------------------------
# SMTP Configuration
# -------------------------------------------------------
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
#   You'll need an App Password (not your regular password).
#   https://support.google.com/accounts/answer/185833
#
# For Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# For Amazon SES: SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# -------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# The "From" address shown in the email
SENDER_EMAIL=your-email@gmail.com

# Where to send the daily report
RECIPIENT_EMAIL=rishabh@bondtrials.com
