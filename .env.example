# -------------------------------------------------------
# SendGrid Configuration
# -------------------------------------------------------
# 1. Sign up at https://sendgrid.com (free: 100 emails/day)
# 2. Go to Settings > API Keys > Create API Key
# 3. Give it "Mail Send" permission, copy the key below
# 4. Verify your sender email under Settings > Sender Authentication
# -------------------------------------------------------

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Must be verified in your SendGrid account
SENDER_EMAIL=your-verified-email@example.com

# Where to send the daily report
RECIPIENT_EMAIL=rishabh@bondtrials.com
